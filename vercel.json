{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "buildCommand": "cd mobile && flutter pub get && flutter build web --release",
  "outputDirectory": "mobile/build/web",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
