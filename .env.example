# Servista Backend Configuration Template
# Duplicate this file as '.env' and fill in your actual values.

# Google Cloud Platform configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Gemini AI API Key
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"

# Firebase Admin SDK Configuration (for auth & push notifications if applicable)
FIREBASE_CREDENTIALS_PATH="firebase-adminsdk.json"

# xAI API Key
XAI_API_KEY="xai-YourxAiApiKeyHere"

# Frontend / Mobile Connection Guide
# Use your local development server network IP (e.g. http://192.168.1.50:8000) 
# so physical Android test devices on the same Wi-Fi can connect.
API_BASE_URL="http://10.8.1.68:8000"
